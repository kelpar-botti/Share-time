# このファイルを .env.local という名前でコピーして、実際の値を入力してください。
# .env.local は Git にコミットされません（.gitignore 済み）。
# 設定手順の詳細は README.md を参照してください。

# --- 管理者 ---
# 管理画面にログインできる唯一のGoogleアカウント（あなたのGmailアドレス）
ADMIN_EMAIL=you@gmail.com

# --- サイトのURL ---
# ローカル開発時はこのままでOK。Vercelにデプロイしたら実際のURLに変更してください。
APP_URL=http://localhost:3000

# --- Google Sign-In (NextAuth) ---
# Google Cloud Console で作成した OAuth クライアントID/シークレット
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# ターミナルで `npx auth secret` を実行するか、ランダムな文字列を自分で生成して設定してください
AUTH_SECRET=

# --- Firebase (Firestore) ---
# Firebase コンソール > プロジェクトの設定 > サービスアカウント で発行した秘密鍵(JSON)の値を使います
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 秘密鍵はダブルクォートで囲み、改行はそのまま \n を含む1行として貼り付けてください
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Gmail送信 (Nodemailer) ---
# 予約通知メールを送信する、あなたのGmailアドレスとアプリパスワード
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=
